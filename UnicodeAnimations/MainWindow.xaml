<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="UnicodeAnimations.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:UnicodeAnimations.ViewModels"
    Title="unicode-animations">

    <!-- Root grid – full dark background -->
    <Grid x:Name="RootGrid">
        <Grid.Background>
            <SolidColorBrush Color="#0B0B0B" />
        </Grid.Background>
        <Grid.RowDefinitions>
            <!-- Custom title bar -->
            <RowDefinition Height="36" />
            <!-- App header -->
            <RowDefinition Height="Auto" />
            <!-- Spinner grid -->
            <RowDefinition Height="*" />
            <!-- Footer -->
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <!-- ─── Custom title bar ──────────────────────────────────────────── -->
        <Grid x:Name="TitleBar" Grid.Row="0" Background="#0B0B0B">
            <TextBlock
                x:Name="TitleText"
                Text="unicode-animations"
                VerticalAlignment="Center"
                Margin="16,0,0,0"
                FontFamily="Cascadia Code, Consolas, Courier New"
                FontSize="12"
                Foreground="#444444" />
        </Grid>

        <!-- ─── Header ────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="1" Margin="28,10,28,0" Spacing="4">
            <TextBlock
                Text="unicode-animations"
                FontSize="22"
                FontWeight="SemiBold"
                FontFamily="Segoe UI Variable Display, Segoe UI"
                Foreground="#E8E8E8" />
            <TextBlock
                Text="18 braille spinner animations — no dependencies, works everywhere."
                FontSize="13"
                Foreground="#555555" />

            <!-- Thin separator -->
            <Border Height="1" Background="#1E1E1E" Margin="0,10,0,0" />
        </StackPanel>

        <!-- ─── Spinner cards ─────────────────────────────────────────────── -->
        <ScrollViewer
            Grid.Row="2"
            Padding="20,16,20,8"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled">

            <ItemsControl x:Name="SpinnersHost">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:SpinnerViewModel">

                        <Border
                            Width="172"
                            Height="112"
                            Margin="6"
                            CornerRadius="10"
                            BorderThickness="1">

                            <Border.Background>
                                <SolidColorBrush Color="#111111" />
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#222222" />
                            </Border.BorderBrush>

                            <!-- Tooltip with frame count -->
                            <ToolTipService.ToolTip>
                                <ToolTip>
                                    <StackPanel Spacing="2">
                                        <TextBlock
                                            Text="{x:Bind Name}"
                                            FontWeight="SemiBold"
                                            Foreground="#E0E0E0" />
                                        <TextBlock
                                            Text="{x:Bind FrameCountLabel}"
                                            Foreground="#888888" />
                                        <TextBlock
                                            Text="{x:Bind IntervalLabel}"
                                            Foreground="#888888" />
                                    </StackPanel>
                                </ToolTip>
                            </ToolTipService.ToolTip>

                            <StackPanel
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="8">

                                <!-- Animated braille frame -->
                                <TextBlock
                                    Text="{x:Bind CurrentFrame, Mode=OneWay}"
                                    FontFamily="Cascadia Code, Consolas, Courier New"
                                    FontSize="20"
                                    Foreground="#00E87A"
                                    HorizontalAlignment="Center"
                                    IsTextSelectionEnabled="False" />

                                <!-- Spinner name -->
                                <TextBlock
                                    Text="{x:Bind Name}"
                                    FontSize="12"
                                    FontWeight="Medium"
                                    Foreground="#7A7A7A"
                                    HorizontalAlignment="Center" />

                                <!-- Interval -->
                                <TextBlock
                                    Text="{x:Bind IntervalLabel}"
                                    FontSize="10"
                                    Foreground="#3A3A3A"
                                    HorizontalAlignment="Center" />

                            </StackPanel>
                        </Border>

                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ─── Footer ────────────────────────────────────────────────────── -->
        <Border Grid.Row="3" BorderThickness="0,1,0,0">
            <Border.BorderBrush>
                <SolidColorBrush Color="#1A1A1A" />
            </Border.BorderBrush>
            <TextBlock
                x:Name="FooterText"
                VerticalAlignment="Center"
                Margin="28,0"
                FontSize="11"
                FontFamily="Cascadia Code, Consolas"
                Foreground="#333333" />
        </Border>

    </Grid>
</Window>
