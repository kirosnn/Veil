<Window
    x:Class="VeilTerminal.TerminalMainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent">
        <Grid x:Name="RootGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TitleBar x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
                <TitleBar.Content>
                    <Grid Margin="8,0,8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ScrollViewer
                            Grid.Column="0"
                            HorizontalScrollBarVisibility="Hidden"
                            HorizontalScrollMode="Enabled"
                            VerticalScrollBarVisibility="Disabled"
                            VerticalScrollMode="Disabled"
                            Padding="0">
                            <StackPanel
                                x:Name="TabStrip"
                                Orientation="Horizontal"
                                Spacing="2"
                                VerticalAlignment="Center" />
                        </ScrollViewer>

                        <Button
                            x:Name="NewTabButton"
                            Grid.Column="1"
                            Width="36"
                            Height="28"
                            Margin="8,0,0,0"
                            Padding="0"
                            CornerRadius="8"
                            BorderThickness="0"
                            Background="Transparent"
                            VerticalAlignment="Center"
                            IsTabStop="False"
                            ToolTipService.ToolTip="New Tab"
                            Click="OnNewTabClick">
                            <TextBlock
                                Text="+"
                                FontSize="18"
                                Foreground="#70FFFFFF"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center" />
                        </Button>
                    </Grid>
                </TitleBar.Content>
            </TitleBar>

            <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1" Background="#10FFFFFF" />

            <Grid Grid.Row="1" Background="#0D1117">
                <Grid x:Name="TerminalHost" />

                <StackPanel
                    x:Name="EmptyStatePanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16"
                    Visibility="Visible">
                    <Image x:Name="EmptyStateLogoImage" Width="72" Height="72" Opacity="0.3" Stretch="Uniform" />
                    <TextBlock
                        Text="Open a new tab to start a terminal session."
                        FontSize="13"
                        FontFamily="{StaticResource SfTextRegular}"
                        Foreground="#40FFFFFF"
                        HorizontalAlignment="Center" />
                    <Button
                        Content="New Tab"
                        HorizontalAlignment="Center"
                        Height="34" Padding="20,0"
                        CornerRadius="10" BorderThickness="0"
                        Background="#18FFFFFF" Foreground="#B0FFFFFF"
                        FontFamily="{StaticResource SfTextMedium}" FontSize="13"
                        IsTabStop="False"
                        Click="OnNewTabClick" />
                </StackPanel>
            </Grid>

        </Grid>

        <Grid x:Name="ProfilePickerOverlay" Background="#80000000" Visibility="Collapsed">
            <Border
                x:Name="ProfilePickerPanel"
                Width="260"
                CornerRadius="14"
                Background="#1A1F29"
                BorderBrush="#18FFFFFF"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="0,12">
                <StackPanel Spacing="0">
                    <TextBlock
                        Text="New Terminal"
                        FontSize="13"
                        FontFamily="{StaticResource SfTextSemibold}"
                        Foreground="#80FFFFFF"
                        Margin="16,0,16,10" />
                    <StackPanel x:Name="ProfileList" Spacing="1" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
