<Window
    x:Class="Veil.Windows.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent" IsTabStop="False">
        <Border
            x:Name="PanelBorder"
            Padding="0"
            Background="#10FFFFFF"
            CornerRadius="0">

            <Grid Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ══ Sidebar ══ -->
                <Border
                    Grid.Column="0"
                    Background="#08FFFFFF"
                    Padding="16,28,12,28">
                    <StackPanel Spacing="2">
                        <TextBlock
                            Text="Settings"
                            FontSize="13"
                            FontFamily="{StaticResource SfTextSemibold}"
                            Foreground="#80FFFFFF"
                            Margin="12,0,0,12" />

                        <Button x:Name="TopBarSectionButton" Height="34" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="12,0" CornerRadius="8" BorderThickness="0" Background="#20FFFFFF" IsTabStop="False" Tag="TopBar" Click="OnSectionButtonClick">
                            <TextBlock Text="Topbar" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" VerticalAlignment="Center" />
                        </Button>
                        <Button x:Name="AiSectionButton" Height="34" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="12,0" CornerRadius="8" BorderThickness="0" Background="Transparent" IsTabStop="False" Tag="AI" Click="OnSectionButtonClick">
                            <TextBlock Text="Dictation" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="#B0FFFFFF" VerticalAlignment="Center" />
                        </Button>
                        <Button x:Name="MenuSectionButton" Height="34" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="12,0" CornerRadius="8" BorderThickness="0" Background="Transparent" IsTabStop="False" Tag="Menu" Click="OnSectionButtonClick">
                            <TextBlock Text="Menu" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="#B0FFFFFF" VerticalAlignment="Center" />
                        </Button>
                        <Button x:Name="DiscordSectionButton" Height="34" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="12,0" CornerRadius="8" BorderThickness="0" Background="Transparent" IsTabStop="False" Tag="Discord" Click="OnSectionButtonClick">
                            <TextBlock Text="Discord" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="#B0FFFFFF" VerticalAlignment="Center" />
                        </Button>
                        <Button x:Name="MusicSectionButton" Height="34" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="12,0" CornerRadius="8" BorderThickness="0" Background="Transparent" IsTabStop="False" Tag="Music" Click="OnSectionButtonClick">
                            <TextBlock Text="Music" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="#B0FFFFFF" VerticalAlignment="Center" />
                        </Button>
                        <Button x:Name="OptimizationSectionButton" Height="34" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="12,0" CornerRadius="8" BorderThickness="0" Background="Transparent" IsTabStop="False" Tag="Optimization" Click="OnSectionButtonClick">
                            <TextBlock Text="Optimization" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="#B0FFFFFF" VerticalAlignment="Center" />
                        </Button>
                        <Button x:Name="RunCatSectionButton" Height="34" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Padding="12,0" CornerRadius="8" BorderThickness="0" Background="Transparent" IsTabStop="False" Tag="RunCat" Click="OnSectionButtonClick">
                            <TextBlock Text="RunCat" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="#B0FFFFFF" VerticalAlignment="Center" />
                        </Button>
                    </StackPanel>
                </Border>

                <!-- ══ Sidebar separator ══ -->
                <Border Grid.Column="0" HorizontalAlignment="Right" Width="1" Background="#10FFFFFF" />

                <!-- ══ Content ══ -->
                <ScrollViewer
                    x:Name="ContentScrollViewer"
                    Grid.Column="1"
                    Padding="56,28,56,28"
                    HorizontalScrollBarVisibility="Disabled"
                    HorizontalScrollMode="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Enabled">

                    <Grid x:Name="ContentHost" HorizontalAlignment="Stretch">
                        <!-- ── Topbar ── -->
                        <Grid x:Name="TopBarSectionPanel" HorizontalAlignment="Stretch">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4" Margin="0,0,0,4">
                                    <TextBlock Text="Topbar" FontSize="20" FontFamily="{StaticResource SfDisplaySemibold}" Foreground="White" />
                                    <TextBlock Text="Tune the visibility and alignment of the bar pinned at the top of your screen." TextWrapping="WrapWholeWords" FontSize="12" FontFamily="{StaticResource SfTextRegular}" Foreground="#90FFFFFF" />
                                </StackPanel>

                                <!-- Screen Placement -->
                                <TextBlock Text="Screen Placement" FontSize="11" FontFamily="{StaticResource SfTextSemibold}" Foreground="#60FFFFFF" Margin="4,0,0,0" CharacterSpacing="40" />
                                <Border Background="#0CFFFFFF" CornerRadius="12" Padding="16,14">
                                    <StackPanel Spacing="14">
                                        <Grid>
                                            <TextBlock Text="Visible On" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" VerticalAlignment="Center" />
                                            <TextBlock x:Name="TopBarDisplayModeValueText" HorizontalAlignment="Right" FontSize="13" FontFamily="{StaticResource SfTextRegular}" Foreground="#80FFFFFF" VerticalAlignment="Center" />
                                        </Grid>
                                        <Grid ColumnSpacing="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="TopBarDisplayModePrimaryButton" Grid.Column="0" Height="32" CornerRadius="8" BorderThickness="0" Background="#20FFFFFF" Foreground="White" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Tag="Primary" Click="OnTopBarDisplayModeButtonClick" Content="Primary" />
                                            <Button x:Name="TopBarDisplayModeAllButton" Grid.Column="1" Height="32" CornerRadius="8" BorderThickness="0" Background="Transparent" Foreground="#B0FFFFFF" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Tag="All" Click="OnTopBarDisplayModeButtonClick" Content="All" />
                                            <Button x:Name="TopBarDisplayModeCustomButton" Grid.Column="2" Height="32" CornerRadius="8" BorderThickness="0" Background="Transparent" Foreground="#B0FFFFFF" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Tag="Custom" Click="OnTopBarDisplayModeButtonClick" Content="Custom" />
                                        </Grid>
                                        <StackPanel x:Name="TopBarMonitorSelectionPanel" Spacing="8" />
                                    </StackPanel>
                                </Border>

                                <!-- Bar Appearance -->
                                <TextBlock Text="Appearance" FontSize="11" FontFamily="{StaticResource SfTextSemibold}" Foreground="#60FFFFFF" Margin="4,8,0,0" CharacterSpacing="40" />
                                <Border Background="#0CFFFFFF" CornerRadius="12" Padding="16,14">
                                    <StackPanel Spacing="14">
                                        <Grid>
                                            <TextBlock Text="Topbar Style" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" VerticalAlignment="Center" />
                                            <TextBlock x:Name="TopBarStyleValueText" HorizontalAlignment="Right" FontSize="13" FontFamily="{StaticResource SfTextRegular}" Foreground="#80FFFFFF" VerticalAlignment="Center" />
                                        </Grid>
                                        <Grid ColumnSpacing="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button x:Name="TopBarStyleSolidButton" Grid.Column="0" Height="32" CornerRadius="8" BorderThickness="0" Background="#20FFFFFF" Foreground="White" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Tag="Solid" Click="OnTopBarStyleButtonClick" Content="Solid" />
                                            <Button x:Name="TopBarStyleBlurButton" Grid.Column="1" Height="32" CornerRadius="8" BorderThickness="0" Background="Transparent" Foreground="#B0FFFFFF" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Tag="Blur" Click="OnTopBarStyleButtonClick" Content="Blur" />
                                            <Button x:Name="TopBarStyleAdaptiveButton" Grid.Column="2" Height="32" CornerRadius="8" BorderThickness="0" Background="Transparent" Foreground="#B0FFFFFF" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Tag="Adaptive" Click="OnTopBarStyleButtonClick" Content="Adaptive" />
                                            <Button x:Name="TopBarStyleTransparentButton" Grid.Column="3" Height="32" CornerRadius="8" BorderThickness="0" Background="Transparent" Foreground="#B0FFFFFF" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Tag="Transparent" Click="OnTopBarStyleButtonClick" Content="Clear" />
                                        </Grid>

                                        <Border Height="1" Background="#08FFFFFF" Margin="0,2" />

                                        <StackPanel x:Name="SolidColorPanel" Spacing="8">
                                            <TextBlock Text="Solid Color" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="SolidColorPreview" Width="32" Height="32" CornerRadius="8" Background="Black" BorderBrush="#20FFFFFF" BorderThickness="1" />
                                                <TextBox x:Name="SolidColorTextBox" Grid.Column="1" PlaceholderText="#000000" MaxLength="7" FontFamily="{StaticResource SfTextMedium}" TextChanged="OnSolidColorChanged" />
                                            </Grid>
                                            <Grid ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Height="24" CornerRadius="6" BorderThickness="0" Background="#FF000000" Tag="#000000" Click="OnSolidColorPresetClick" />
                                                <Button Grid.Column="1" Height="24" CornerRadius="6" BorderThickness="0" Background="#FFFFFFFF" Tag="#FFFFFF" Click="OnSolidColorPresetClick" />
                                                <Button Grid.Column="2" Height="24" CornerRadius="6" BorderThickness="0" Background="#FF1F2937" Tag="#1F2937" Click="OnSolidColorPresetClick" />
                                                <Button Grid.Column="3" Height="24" CornerRadius="6" BorderThickness="0" Background="#FF0F766E" Tag="#0F766E" Click="OnSolidColorPresetClick" />
                                                <Button Grid.Column="4" Height="24" CornerRadius="6" BorderThickness="0" Background="#FF7C2D12" Tag="#7C2D12" Click="OnSolidColorPresetClick" />
                                                <Button Grid.Column="5" Height="24" CornerRadius="6" BorderThickness="0" Background="#FF312E81" Tag="#312E81" Click="OnSolidColorPresetClick" />
                                            </Grid>
                                        </StackPanel>

                                        <Border Height="1" Background="#08FFFFFF" Margin="0,2" />

                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Icon and Text Color" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="TopBarForegroundColorPreview" Width="32" Height="32" CornerRadius="8" Background="White" BorderBrush="#20FFFFFF" BorderThickness="1" />
                                                <TextBox x:Name="TopBarForegroundColorTextBox" Grid.Column="1" PlaceholderText="#FFFFFF" MaxLength="7" FontFamily="{StaticResource SfTextMedium}" TextChanged="OnTopBarForegroundColorChanged" />
                                            </Grid>
                                            <Grid ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Height="24" CornerRadius="6" BorderThickness="0" Background="#FFFFFFFF" Tag="#FFFFFF" Click="OnTopBarForegroundColorPresetClick" />
                                                <Button Grid.Column="1" Height="24" CornerRadius="6" BorderThickness="0" Background="#FF000000" Tag="#000000" Click="OnTopBarForegroundColorPresetClick" />
                                                <Button Grid.Column="2" Height="24" CornerRadius="6" BorderThickness="0" Background="#FFFDE047" Tag="#FDE047" Click="OnTopBarForegroundColorPresetClick" />
                                                <Button Grid.Column="3" Height="24" CornerRadius="6" BorderThickness="0" Background="#FF60A5FA" Tag="#60A5FA" Click="OnTopBarForegroundColorPresetClick" />
                                                <Button Grid.Column="4" Height="24" CornerRadius="6" BorderThickness="0" Background="#FFFCA5A5" Tag="#FCA5A5" Click="OnTopBarForegroundColorPresetClick" />
                                                <Button Grid.Column="5" Height="24" CornerRadius="6" BorderThickness="0" Background="#FF86EFAC" Tag="#86EFAC" Click="OnTopBarForegroundColorPresetClick" />
                                            </Grid>
                                        </StackPanel>

                                        <Border Height="1" Background="#08FFFFFF" Margin="0,2" />

                                        <StackPanel x:Name="BlurIntensityPanel" Spacing="6">
                                            <Grid>
                                                <TextBlock Text="Blur Intensity" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                                <TextBlock x:Name="BlurIntensityValueText" HorizontalAlignment="Right" FontSize="13" FontFamily="{StaticResource SfTextRegular}" Foreground="#80FFFFFF" />
                                            </Grid>
                                            <Slider x:Name="BlurIntensitySlider" IsTabStop="False" ValueChanged="OnBlurIntensityChanged" />
                                        </StackPanel>

                                        <StackPanel x:Name="TopBarOpacityPanel" Spacing="6">
                                            <Grid>
                                                <TextBlock Text="Topbar Opacity" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                                <TextBlock x:Name="TopBarOpacityValueText" HorizontalAlignment="Right" FontSize="13" FontFamily="{StaticResource SfTextRegular}" Foreground="#80FFFFFF" />
                                            </Grid>
                                            <Slider x:Name="TopBarOpacitySlider" IsTabStop="False" ValueChanged="OnTopBarOpacityChanged" />
                                        </StackPanel>

                                        <StackPanel Spacing="6">
                                            <Grid>
                                                <TextBlock Text="Clock Center Offset" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                                <TextBlock x:Name="ClockOffsetValueText" HorizontalAlignment="Right" FontSize="13" FontFamily="{StaticResource SfTextRegular}" Foreground="#80FFFFFF" />
                                            </Grid>
                                            <Slider x:Name="ClockOffsetSlider" IsTabStop="False" ValueChanged="OnClockOffsetChanged" />
                                        </StackPanel>

                                        <StackPanel Spacing="8">
                                            <Grid>
                                                <TextBlock Text="Topbar Alignment" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                                <TextBlock x:Name="TopBarContentAlignmentValueText" HorizontalAlignment="Right" FontSize="13" FontFamily="{StaticResource SfTextRegular}" Foreground="#80FFFFFF" />
                                            </Grid>
                                            <Grid ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="TopBarContentAlignmentCenterButton" Grid.Column="0" Height="32" CornerRadius="8" BorderThickness="0" Background="#20FFFFFF" Foreground="White" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Tag="Center" Click="OnTopBarContentAlignmentButtonClick" Content="Center" />
                                                <Button x:Name="TopBarContentAlignmentRightButton" Grid.Column="1" Height="32" CornerRadius="8" BorderThickness="0" Background="Transparent" Foreground="#B0FFFFFF" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Tag="Right" Click="OnTopBarContentAlignmentButtonClick" Content="Right" />
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Raycast detected notice -->
                                <Border x:Name="RaycastNoticeBorder" Background="#0C4ADE94" CornerRadius="12" Padding="14,10" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="✦" FontSize="13" Foreground="#4ADE94" VerticalAlignment="Center" />
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Raycast detected" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="#4ADE94" />
                                            <TextBlock Text="Finder is delegated to Raycast. The Ctrl+Space hotkey is disabled to avoid conflicts." FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#90FFFFFF" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Toggles -->
                                <Border Background="#0CFFFFFF" CornerRadius="12" Padding="16,14">
                                    <StackPanel Spacing="14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Show Finder Bubble" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                                <TextBlock Text="Display the capsule behind the application name." FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#70FFFFFF" />
                                            </StackPanel>
                                            <Button x:Name="ShowFinderBubbleButton" Grid.Column="1" Width="80" Height="30" VerticalAlignment="Center" CornerRadius="8" BorderThickness="0" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Click="OnShowFinderBubbleButtonClick" Content="Enabled" />
                                        </Grid>

                                        <Border Height="1" Background="#08FFFFFF" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Finder Shortcut" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                                <TextBlock Text="Open Finder with Ctrl+Space." FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#70FFFFFF" />
                                            </StackPanel>
                                            <Button x:Name="FinderHotkeyButton" Grid.Column="1" Width="80" Height="30" VerticalAlignment="Center" CornerRadius="8" BorderThickness="0" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Click="OnFinderHotkeyButtonClick" Content="Enabled" />
                                        </Grid>

                                        <Border Height="1" Background="#08FFFFFF" />

                                        <StackPanel Spacing="6">
                                            <Grid>
                                                <TextBlock Text="Finder Bubble Strength" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                                <TextBlock x:Name="FinderBubbleValueText" HorizontalAlignment="Right" FontSize="13" FontFamily="{StaticResource SfTextRegular}" Foreground="#80FFFFFF" />
                                            </Grid>
                                            <Slider x:Name="FinderBubbleSlider" IsTabStop="False" ValueChanged="OnFinderBubbleChanged" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- App Buttons -->
                                <TextBlock Text="App Buttons" FontSize="11" FontFamily="{StaticResource SfTextSemibold}" Foreground="#60FFFFFF" Margin="4,8,0,0" CharacterSpacing="40" />
                                <Border Background="#0CFFFFFF" CornerRadius="12" Padding="16,14">
                                    <StackPanel Spacing="14">
                                        <TextBlock Text="Configure up to four buttons shown after Finder." TextWrapping="WrapWholeWords" FontSize="12" FontFamily="{StaticResource SfTextRegular}" Foreground="#80FFFFFF" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="App Button Outline" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                                <TextBlock Text="Show the contour around the app buttons group in the topbar." FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#70FFFFFF" TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                            <Button x:Name="AppButtonOutlineButton" Grid.Column="1" Width="80" Height="30" VerticalAlignment="Center" CornerRadius="8" BorderThickness="0" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Click="OnAppButtonOutlineButtonClick" Content="Enabled" />
                                        </Grid>

                                        <Border Height="1" Background="#08FFFFFF" />

                                        <Grid RowSpacing="10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" Spacing="8">
                                                <ComboBox x:Name="ShortcutSlot1ComboBox" Header="Button 1 App" DisplayMemberPath="Name" SelectionChanged="OnShortcutSelectionChanged" Tag="0" />
                                                <TextBox x:Name="ShortcutSlot1NameTextBox" Header="Button 1 Label" PlaceholderText="Finder-style label" TextChanged="OnShortcutNameChanged" Tag="0" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="1" Spacing="8">
                                                <ComboBox x:Name="ShortcutSlot2ComboBox" Header="Button 2 App" DisplayMemberPath="Name" SelectionChanged="OnShortcutSelectionChanged" Tag="1" />
                                                <TextBox x:Name="ShortcutSlot2NameTextBox" Header="Button 2 Label" PlaceholderText="Finder-style label" TextChanged="OnShortcutNameChanged" Tag="1" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Spacing="8">
                                                <ComboBox x:Name="ShortcutSlot3ComboBox" Header="Button 3 App" DisplayMemberPath="Name" SelectionChanged="OnShortcutSelectionChanged" Tag="2" />
                                                <TextBox x:Name="ShortcutSlot3NameTextBox" Header="Button 3 Label" PlaceholderText="Finder-style label" TextChanged="OnShortcutNameChanged" Tag="2" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="3" Spacing="8">
                                                <ComboBox x:Name="ShortcutSlot4ComboBox" Header="Button 4 App" DisplayMemberPath="Name" SelectionChanged="OnShortcutSelectionChanged" Tag="3" />
                                                <TextBox x:Name="ShortcutSlot4NameTextBox" Header="Button 4 Label" PlaceholderText="Finder-style label" TextChanged="OnShortcutNameChanged" Tag="3" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="4" Spacing="8">
                                                <ComboBox x:Name="ShortcutSlot5ComboBox" Header="Button 5 App" DisplayMemberPath="Name" SelectionChanged="OnShortcutSelectionChanged" Tag="4" />
                                                <TextBox x:Name="ShortcutSlot5NameTextBox" Header="Button 5 Label" PlaceholderText="Finder-style label" TextChanged="OnShortcutNameChanged" Tag="4" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="5" Spacing="8">
                                                <ComboBox x:Name="ShortcutSlot6ComboBox" Header="Button 6 App" DisplayMemberPath="Name" SelectionChanged="OnShortcutSelectionChanged" Tag="5" />
                                                <TextBox x:Name="ShortcutSlot6NameTextBox" Header="Button 6 Label" PlaceholderText="Finder-style label" TextChanged="OnShortcutNameChanged" Tag="5" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- ── Dictation ── -->
                        <Grid x:Name="AiSectionPanel" Visibility="Collapsed" HorizontalAlignment="Stretch">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4" Margin="0,0,0,4">
                                    <TextBlock Text="Dictation" FontSize="20" FontFamily="{StaticResource SfDisplaySemibold}" Foreground="White" />
                                    <TextBlock Text="Configure offline speech recognition for dictation. Models run entirely on-device." TextWrapping="WrapWholeWords" FontSize="12" FontFamily="{StaticResource SfTextRegular}" Foreground="#90FFFFFF" />
                                </StackPanel>

                                <TextBlock Text="Speech Models" FontSize="11" FontFamily="{StaticResource SfTextSemibold}" Foreground="#60FFFFFF" Margin="4,0,0,0" CharacterSpacing="40" />
                                <Border Background="#0FFFFFFF" BorderBrush="#12FFFFFF" BorderThickness="1" CornerRadius="18" Padding="18,16">
                                    <StackPanel Spacing="14">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="Local Speech Model Library" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                                <TextBlock Text="Download curated offline speech models for future use inside Veil. Files stay local under Veil's app data folder. Custom model sideloading is intentionally not supported." TextWrapping="WrapWholeWords" FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#80FFFFFF" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Padding="10,5" CornerRadius="8" Background="#18FFFFFF" VerticalAlignment="Top">
                                                <TextBlock x:Name="AiSpeechModelLibraryBadgeText" Text="Catalog" FontSize="11" FontFamily="{StaticResource SfTextSemibold}" Foreground="#E6FFFFFF" />
                                            </Border>
                                        </Grid>

                                        <ComboBox x:Name="AiSpeechModelComboBox" Header="Preferred Local Speech Model" DisplayMemberPath="DisplayName" SelectionChanged="OnAiSpeechModelSelectionChanged" />

                                        <Border Background="#12FFFFFF" BorderBrush="#10FFFFFF" BorderThickness="1" CornerRadius="14" Padding="14,12">
                                            <StackPanel Spacing="10">
                                                <StackPanel Spacing="3">
                                                    <TextBlock x:Name="AiSpeechModelTitleText" Text="Parakeet V3" FontSize="15" FontFamily="{StaticResource SfDisplaySemibold}" Foreground="White" />
                                                    <TextBlock x:Name="AiSpeechModelDescriptionText" TextWrapping="WrapWholeWords" FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#B8FFFFFF" />
                                                </StackPanel>

                                                <TextBlock x:Name="AiSpeechModelMetaText" TextWrapping="WrapWholeWords" FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#90FFFFFF" />
                                                <TextBlock x:Name="AiSpeechModelCapabilitiesText" TextWrapping="WrapWholeWords" FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#90FFFFFF" />
                                                <TextBlock x:Name="AiSpeechModelOutputText" TextWrapping="WrapWholeWords" FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#90FFFFFF" />
                                                <TextBlock x:Name="AiSpeechModelStoragePathText" TextWrapping="WrapWholeWords" FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#72FFFFFF" />

                                                <ProgressBar x:Name="AiSpeechModelProgressBar" Minimum="0" Maximum="100" Height="6" Visibility="Collapsed" />
                                                <TextBlock x:Name="AiSpeechModelStatusText" TextWrapping="WrapWholeWords" FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#C8FFFFFF" />

                                                <Grid ColumnSpacing="6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button x:Name="AiSpeechModelPrimaryActionButton" Grid.Column="0" Height="30" Padding="14,0" CornerRadius="8" BorderThickness="0" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Click="OnAiSpeechModelPrimaryActionClick" Content="Download" />
                                                    <Button x:Name="AiSpeechModelSecondaryActionButton" Grid.Column="1" Height="30" Padding="14,0" CornerRadius="8" BorderThickness="0" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Click="OnAiSpeechModelSecondaryActionClick" Content="Delete" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="OptimizationSectionPanel" Visibility="Collapsed" HorizontalAlignment="Stretch">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4" Margin="0,0,0,4">
                                    <TextBlock Text="Optimization" FontSize="20" FontFamily="{StaticResource SfDisplaySemibold}" Foreground="White" />
                                    <TextBlock Text="Control Veil's own background maintenance without changing game, app, or system process behavior." TextWrapping="WrapWholeWords" FontSize="12" FontFamily="{StaticResource SfTextRegular}" Foreground="#90FFFFFF" />
                                </StackPanel>

                                <Border Background="#0CFFFFFF" CornerRadius="12" Padding="16,14">
                                    <StackPanel Spacing="14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Veil memory maintenance" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                                <TextBlock Text="Periodically compact Veil's managed memory and trim Veil's working set when it grows too large." FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#70FFFFFF" TextWrapping="WrapWholeWords" />
                                            </StackPanel>
                                            <Button x:Name="BackgroundOptimizationEnabledButton" Grid.Column="1" Width="80" Height="30" VerticalAlignment="Center" CornerRadius="8" BorderThickness="0" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Click="OnBackgroundOptimizationEnabledButtonClick" Content="Enabled" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- ── Discord ── -->
                        <Grid x:Name="DiscordSectionPanel" Visibility="Collapsed" HorizontalAlignment="Stretch">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4" Margin="0,0,0,4">
                                    <TextBlock Text="Discord" FontSize="20" FontFamily="{StaticResource SfDisplaySemibold}" Foreground="White" />
                                    <TextBlock Text="Use the Discord topbar button as a lightweight inbox." TextWrapping="WrapWholeWords" FontSize="12" FontFamily="{StaticResource SfTextRegular}" Foreground="#90FFFFFF" />
                                </StackPanel>

                                <Border Background="#0CFFFFFF" CornerRadius="12" Padding="16,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Enable Discord Button" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                            <TextBlock Text="Show the Discord button when Discord is running or notifications are available." FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#70FFFFFF" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                        <Button x:Name="DiscordButtonEnabledButton" Grid.Column="1" Width="80" Height="30" VerticalAlignment="Center" CornerRadius="8" BorderThickness="0" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Click="OnDiscordButtonEnabledButtonClick" Content="Enabled" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- ── Music ── -->
                        <Grid x:Name="MusicSectionPanel" Visibility="Collapsed" HorizontalAlignment="Stretch">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4" Margin="0,0,0,4">
                                    <TextBlock Text="Music" FontSize="20" FontFamily="{StaticResource SfDisplaySemibold}" Foreground="White" />
                                    <TextBlock Text="Choose how the Music button behaves in the topbar." TextWrapping="WrapWholeWords" FontSize="12" FontFamily="{StaticResource SfTextRegular}" Foreground="#90FFFFFF" />
                                </StackPanel>

                                <Border Background="#0CFFFFFF" CornerRadius="12" Padding="16,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Enable Music Button" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                            <TextBlock Text="Show the Music button when a supported player is active." FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#70FFFFFF" />
                                        </StackPanel>
                                        <Button x:Name="MusicButtonEnabledButton" Grid.Column="1" Width="80" Height="30" VerticalAlignment="Center" CornerRadius="8" BorderThickness="0" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Click="OnMusicButtonEnabledButtonClick" Content="Enabled" />
                                    </Grid>
                                </Border>

                                <TextBlock Text="Popup" FontSize="11" FontFamily="{StaticResource SfTextSemibold}" Foreground="#60FFFFFF" Margin="4,8,0,0" CharacterSpacing="40" />
                                <Border Background="#0CFFFFFF" CornerRadius="12" Padding="16,14">
                                    <StackPanel Spacing="14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Show Volume Control" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                                <TextBlock Text="Display the volume slider inside the Music popup." FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#70FFFFFF" />
                                            </StackPanel>
                                            <Button x:Name="MusicShowVolumeButton" Grid.Column="1" Width="80" Height="30" VerticalAlignment="Center" CornerRadius="8" BorderThickness="0" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Click="OnMusicShowVolumeButtonClick" Content="Enabled" />
                                        </Grid>

                                        <Border Height="1" Background="#08FFFFFF" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Show Hide or Reopen Action" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                                <TextBlock Text="Keep the source app action at the bottom of the popup." FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#70FFFFFF" />
                                            </StackPanel>
                                            <Button x:Name="MusicShowSourceToggleButton" Grid.Column="1" Width="80" Height="30" VerticalAlignment="Center" CornerRadius="8" BorderThickness="0" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Click="OnMusicShowSourceToggleButtonClick" Content="Enabled" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- ── Menu ── -->
                        <Grid x:Name="MenuSectionPanel" Visibility="Collapsed" HorizontalAlignment="Stretch">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4" Margin="0,0,0,4">
                                    <TextBlock Text="Menu" FontSize="20" FontFamily="{StaticResource SfDisplaySemibold}" Foreground="White" />
                                    <TextBlock Text="Control the floating dropdown appearance." TextWrapping="WrapWholeWords" FontSize="12" FontFamily="{StaticResource SfTextRegular}" Foreground="#90FFFFFF" />
                                </StackPanel>

                                <Border Background="#0CFFFFFF" CornerRadius="12" Padding="16,14">
                                    <StackPanel Spacing="6">
                                        <Grid>
                                            <TextBlock Text="Menu Acrylic Strength" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                            <TextBlock x:Name="MenuTintValueText" HorizontalAlignment="Right" FontSize="13" FontFamily="{StaticResource SfTextRegular}" Foreground="#80FFFFFF" />
                                        </Grid>
                                        <Slider x:Name="MenuTintSlider" IsTabStop="False" ValueChanged="OnMenuTintChanged" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- ── RunCat ── -->
                        <Grid x:Name="RunCatSectionPanel" Visibility="Collapsed" HorizontalAlignment="Stretch">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4" Margin="0,0,0,4">
                                    <TextBlock Text="RunCat" FontSize="20" FontFamily="{StaticResource SfDisplaySemibold}" Foreground="White" />
                                    <TextBlock Text="A running character whose speed reflects free system and GPU memory." TextWrapping="WrapWholeWords" FontSize="12" FontFamily="{StaticResource SfTextRegular}" Foreground="#90FFFFFF" />
                                </StackPanel>

                                <Border Background="#0CFFFFFF" CornerRadius="12" Padding="16,14">
                                    <StackPanel Spacing="14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="Enable RunCat" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" />
                                                <TextBlock Text="Less free memory means faster animation." FontSize="11" FontFamily="{StaticResource SfTextRegular}" Foreground="#70FFFFFF" />
                                            </StackPanel>
                                            <Button x:Name="RunCatEnabledButton" Grid.Column="1" Width="80" Height="30" VerticalAlignment="Center" CornerRadius="8" BorderThickness="0" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Click="OnRunCatEnabledButtonClick" Content="Disabled" />
                                        </Grid>

                                        <Border Height="1" Background="#08FFFFFF" />

                                        <StackPanel Spacing="8">
                                            <Grid>
                                                <TextBlock Text="Runner" FontSize="13" FontFamily="{StaticResource SfTextMedium}" Foreground="White" VerticalAlignment="Center" />
                                                <TextBlock x:Name="RunCatRunnerValueText" HorizontalAlignment="Right" FontSize="13" FontFamily="{StaticResource SfTextRegular}" Foreground="#80FFFFFF" VerticalAlignment="Center" />
                                            </Grid>
                                            <Grid ColumnSpacing="6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Button x:Name="RunCatCatButton" Grid.Column="0" Height="32" CornerRadius="8" BorderThickness="0" Background="#20FFFFFF" Foreground="White" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Tag="Cat" Click="OnRunCatRunnerButtonClick" Content="Cat" />
                                                <Button x:Name="RunCatParrotButton" Grid.Column="1" Height="32" CornerRadius="8" BorderThickness="0" Background="Transparent" Foreground="#B0FFFFFF" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Tag="Parrot" Click="OnRunCatRunnerButtonClick" Content="Parrot" />
                                                <Button x:Name="RunCatHorseButton" Grid.Column="2" Height="32" CornerRadius="8" BorderThickness="0" Background="Transparent" Foreground="#B0FFFFFF" FontFamily="{StaticResource SfTextMedium}" FontSize="12" IsTabStop="False" Tag="Horse" Click="OnRunCatRunnerButtonClick" Content="Horse" />
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>

                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
