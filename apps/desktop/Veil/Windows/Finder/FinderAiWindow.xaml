<Window
    x:Class="Veil.Windows.FinderAiWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent">
        <Border
            Margin="10"
            CornerRadius="22"
            BorderThickness="0"
            Background="Transparent">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="182" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    x:Name="SidebarPanel"
                    Grid.Column="0"
                    Background="Transparent"
                    CornerRadius="22,0,0,22">
                    <Grid Margin="10,10,10,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="1" Margin="0,8,0,0" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button
                                x:Name="NewChatButton"
                                Height="30"
                                CornerRadius="8"
                                BorderThickness="0"
                                Background="#12FFFFFF"
                                Foreground="White"
                                FontFamily="{StaticResource SfTextSemibold}"
                                FontSize="11"
                                Content="New Chat"
                                Click="OnNewChatClick" />

                            <Button
                                x:Name="DeleteChatButton"
                                Grid.Column="1"
                                Height="30"
                                Padding="10,0"
                                CornerRadius="8"
                                BorderThickness="0"
                                Background="Transparent"
                                Foreground="#C6FFFFFF"
                                FontFamily="{StaticResource SfTextMedium}"
                                FontSize="11"
                                Content="Delete"
                                Click="OnDeleteChatClick" />
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,12,0,0">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                                <StackPanel x:Name="HistoryListPanel" Spacing="6" />
                            </ScrollViewer>

                            <TextBlock
                                x:Name="HistoryEmptyText"
                                Text="No saved conversation yet."
                                TextWrapping="WrapWholeWords"
                                FontSize="11"
                                FontFamily="{StaticResource SfTextRegular}"
                                Foreground="#78FFFFFF"
                                VerticalAlignment="Top" />
                        </Grid>

                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="10,10,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="8">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="220" />
                            </Grid.ColumnDefinitions>

                            <Button
                                x:Name="BackToFinderButton"
                                Width="94"
                                Height="32"
                                Padding="0"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Left"
                                Background="#14FFFFFF"
                                Click="OnBackToFinderClick">
                                <StackPanel Orientation="Horizontal" Spacing="7">
                                    <TextBlock Text="←" FontSize="14" FontFamily="{StaticResource SfTextMedium}" />
                                    <TextBlock Text="Finder" FontSize="11.5" FontFamily="{StaticResource SfTextSemibold}" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="SidebarToggleButton"
                                Grid.Column="1"
                                Width="32"
                                Height="32"
                                Padding="0"
                                VerticalAlignment="Top"
                                HorizontalAlignment="Left"
                                Background="#10FFFFFF"
                                Foreground="#F0FFFFFF"
                                Click="OnToggleSidebarClick">
                                <Viewbox Width="14" Height="14">
                                    <Canvas Width="20" Height="20">
                                        <Path
                                            Fill="#F0FFFFFF"
                                            Data="M16.5 4A1.5 1.5 0 0 1 18 5.5v9a1.5 1.5 0 0 1-1.5 1.5h-13A1.5 1.5 0 0 1 2 14.5v-9A1.5 1.5 0 0 1 3.5 4zM7 15h9.5a.5.5 0 0 0 .5-.5v-9a.5.5 0 0 0-.5-.5H7zM3.5 5a.5.5 0 0 0-.5.5v9a.5.5 0 0 0 .5.5H6V5z" />
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <Grid Grid.Column="2" />

                            <StackPanel Grid.Column="3" Spacing="6">
                                <Button
                                    x:Name="ModelSelectorButton"
                                    Height="32"
                                    Padding="12,0"
                                    HorizontalAlignment="Stretch"
                                    Background="#10FFFFFF"
                                    Click="OnModelSelectorClick">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            x:Name="ModelSelectionTextBlock"
                                            VerticalAlignment="Center"
                                            Text="Select model"
                                            TextTrimming="CharacterEllipsis"
                                            FontFamily="{StaticResource SfTextSemibold}"
                                            FontSize="11.5" />

                                        <TextBlock
                                            x:Name="ModelSelectorChevronTextBlock"
                                            Grid.Column="1"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            Text="▾"
                                            FontSize="12"
                                            FontFamily="{StaticResource SfTextMedium}" />
                                    </Grid>
                                </Button>

                                <Border
                                    x:Name="ModelDropdownPanel"
                                    Visibility="Collapsed"
                                    Background="#141A22"
                                    CornerRadius="12"
                                    BorderBrush="#16FFFFFF"
                                    BorderThickness="1"
                                    Padding="6">
                                    <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Enabled">
                                        <StackPanel x:Name="ModelOptionsPanel" Spacing="4" />
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,12,0,12">
                        <Grid x:Name="ConversationPanel">
                            <ScrollViewer
                                x:Name="MessagesScrollViewer"
                                VerticalScrollBarVisibility="Auto"
                                VerticalScrollMode="Enabled">
                                <StackPanel
                                    x:Name="MessagesPanel"
                                    Spacing="10"
                                    Padding="0,2,2,2" />
                            </ScrollViewer>
                        </Grid>

                        <Border
                            x:Name="HomePagePanel"
                            Background="Transparent">
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="10"
                                MaxWidth="460">
                                <TextBlock
                                    Text="Ask anything about this machine, the current project, or the next step."
                                    FontSize="12"
                                    FontFamily="{StaticResource SfTextRegular}"
                                    Foreground="#90FFFFFF"
                                    HorizontalAlignment="Left"
                                    TextWrapping="WrapWholeWords" />

                                <Border
                                    Background="#0CFFFFFF"
                                    CornerRadius="10"
                                    BorderBrush="#10FFFFFF"
                                    BorderThickness="1"
                                    Padding="10,10,8,8">
                                    <Grid RowSpacing="8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBox
                                            x:Name="HomeComposerTextBox"
                                            MinHeight="48"
                                            MaxHeight="112"
                                            AcceptsReturn="True"
                                            TextWrapping="Wrap"
                                            BorderThickness="0"
                                            Background="Transparent"
                                            Foreground="White"
                                            PlaceholderText="Plan, build, / for commands, @ for context"
                                            FontSize="14"
                                            FontFamily="{StaticResource SfTextRegular}"
                                            Padding="0"
                                            VerticalAlignment="Center"
                                            KeyDown="OnHomeComposerKeyDown" />

                                        <Grid Grid.Row="1" ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Button
                                                x:Name="HomeSendButton"
                                                Grid.Column="1"
                                                Width="34"
                                                Height="34"
                                                Padding="0"
                                                CornerRadius="8"
                                                BorderThickness="0"
                                                Background="#22FFFFFF"
                                                Foreground="#F2FFFFFF"
                                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                                FontSize="12"
                                                Content="&#xE724;"
                                                Click="OnHomeSendClick" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel x:Name="ConversationComposerPanel" Grid.Row="2" Spacing="8">
                        <Border
                            Background="#0CFFFFFF"
                            CornerRadius="10"
                            BorderBrush="#10FFFFFF"
                            BorderThickness="1"
                            Padding="10,10,8,8">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBox
                                    x:Name="ComposerTextBox"
                                    MinHeight="48"
                                    MaxHeight="128"
                                    AcceptsReturn="True"
                                    TextWrapping="Wrap"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Foreground="White"
                                    PlaceholderText="Ask anything about this machine, this project, or the next step..."
                                    FontSize="14"
                                    FontFamily="{StaticResource SfTextRegular}"
                                    Padding="0"
                                    VerticalAlignment="Center"
                                    KeyDown="OnComposerKeyDown" />

                                <Button
                                    x:Name="SendButton"
                                    Grid.Column="1"
                                    Width="34"
                                    Height="34"
                                    VerticalAlignment="Bottom"
                                    Padding="0"
                                    CornerRadius="8"
                                    BorderThickness="0"
                                    Background="#22FFFFFF"
                                    Foreground="#F2FFFFFF"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="12"
                                    Content="&#xE724;"
                                    Click="OnSendClick" />
                            </Grid>
                        </Border>

                        <TextBlock
                            x:Name="StatusTextBlock"
                            FontSize="10"
                            FontFamily="{StaticResource SfTextRegular}"
                            Foreground="#8EFFFFFF"
                            TextWrapping="WrapWholeWords"
                            VerticalAlignment="Center"
                            Visibility="Collapsed" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
