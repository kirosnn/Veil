<Window
    x:Class="Veil.Windows.FinderAiWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent">
        <Border
            x:Name="PanelBorder"
            Margin="10"
            Background="#080C14"
            CornerRadius="22"
            BorderBrush="#16FFFFFF"
            BorderThickness="1">
            <Grid>
                <Grid x:Name="WebViewHost" />

                <Border
                    x:Name="LoadingOverlay"
                    Background="#AA0B0F16"
                    CornerRadius="22">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                        <ProgressRing IsActive="True" Width="32" Height="32" />
                        <TextBlock
                            x:Name="LoadingTextBlock"
                            Text="Loading Finder AI"
                            Foreground="#E8FFFFFF"
                            FontFamily="{StaticResource SfTextMedium}"
                            FontSize="13"
                            HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
