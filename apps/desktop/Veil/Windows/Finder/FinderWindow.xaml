<Window
    x:Class="Veil.Windows.FinderWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent" IsTabStop="False">
        <Border
            x:Name="PanelBorder"
            Padding="0"
            Background="#10FFFFFF"
            BorderBrush="#14FFFFFF"
            BorderThickness="1"
            CornerRadius="24">

            <Grid Margin="0,18,0,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Height="46" Margin="18,0,18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        x:Name="SearchIcon"
                        Text="&#xE721;"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="17"
                        Foreground="#7AFFFFFF"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0" />

                    <Grid Grid.Column="1">
                        <TextBlock
                            x:Name="SearchPlaceholder"
                            Text="Search apps, settings, or actions"
                            FontSize="20"
                            FontFamily="{StaticResource SfTextRegular}"
                            Foreground="#42FFFFFF"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False" />

                        <TextBlock
                            x:Name="AutocompleteHint"
                            FontSize="20"
                            FontFamily="{StaticResource SfTextRegular}"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            Visibility="Collapsed" />

                        <TextBox
                            x:Name="SearchTextBox"
                            BorderThickness="0"
                            Background="Transparent"
                            Foreground="White"
                            FontSize="20"
                            FontFamily="{StaticResource SfTextRegular}"
                            VerticalAlignment="Center"
                            Padding="0"
                            SelectionHighlightColor="#4488AAFF"
                            TextChanged="OnSearchTextChanged"
                            KeyDown="OnSearchKeyDown">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="MinWidth" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <ScrollViewer
                                                    x:Name="ContentElement"
                                                    HorizontalScrollBarVisibility="Hidden"
                                                    HorizontalScrollMode="Auto"
                                                    VerticalScrollBarVisibility="Disabled"
                                                    VerticalScrollMode="Disabled"
                                                    VerticalAlignment="Center"
                                                    Margin="0"
                                                    Padding="0" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Grid>

                <Border
                    x:Name="Separator"
                    Grid.Row="1"
                    Height="1"
                    Margin="0,14,0,12"
                    Background="#10FFFFFF" />

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Padding="18,0,18,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            x:Name="SectionTitleText"
                            Text="Applications"
                            FontSize="13"
                            FontFamily="{StaticResource SfTextSemibold}"
                            Foreground="#EDEDED"
                            VerticalAlignment="Center" />

                        <TextBlock
                            x:Name="SectionSubtitleText"
                            Grid.Column="1"
                            Text=""
                            FontSize="11"
                            FontFamily="{StaticResource SfTextRegular}"
                            Foreground="#00000000"
                            Visibility="Collapsed" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <ScrollViewer
                            x:Name="ResultsScrollViewer"
                            Padding="8,0,8,8"
                            VerticalScrollBarVisibility="Hidden"
                            VerticalScrollMode="Auto">
                            <StackPanel x:Name="ResultsPanel" Spacing="4" />
                        </ScrollViewer>

                        <Border
                            x:Name="EmptyStatePanel"
                            Background="Transparent"
                            Visibility="Collapsed">
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                                <TextBlock
                                    Text="&#xE721;"
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="20"
                                    Foreground="#72FFFFFF"
                                    HorizontalAlignment="Center" />

                                <TextBlock
                                    x:Name="EmptyStateTitleText"
                                    Text="No Results"
                                    FontSize="16"
                                    FontFamily="{StaticResource SfTextSemibold}"
                                    Foreground="#D0FFFFFF"
                                    HorizontalAlignment="Center" />

                                <TextBlock
                                    x:Name="EmptyStateSubtitleText"
                                    Text="Try a different search."
                                    FontSize="12"
                                    FontFamily="{StaticResource SfTextRegular}"
                                    Foreground="#76FFFFFF"
                                    HorizontalAlignment="Center"
                                    TextAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <Grid
                    x:Name="StatusBar"
                    Grid.Row="3"
                    Margin="18,10,18,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        x:Name="ResultCountText"
                        Text=""
                        FontSize="11"
                        FontFamily="{StaticResource SfTextMedium}"
                        Foreground="#7CFFFFFF"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left" />

                    <TextBlock
                        x:Name="HintText"
                        Grid.Column="1"
                        Text="Enter open  •  Tab complete"
                        FontSize="11"
                        FontFamily="{StaticResource SfTextRegular}"
                        Foreground="#7CFFFFFF"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right" />
                </Grid>

                <Border
                    x:Name="SearchShortcutHint"
                    Visibility="Collapsed" />
            </Grid>
        </Border>
    </Grid>
</Window>
