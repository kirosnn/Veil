<Window
    x:Class="Veil.Windows.DockWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="Transparent">
        <Grid VerticalAlignment="Bottom" Margin="0,0,0,14">
            <Border
                x:Name="DockSurfaceBorder"
                HorizontalAlignment="Center"
                MinWidth="220"
                MaxWidth="1220"
                Padding="18,14,18,12"
                Background="#C81A202B"
                BorderBrush="#40FFFFFF"
                BorderThickness="1"
                CornerRadius="30">
                <StackPanel Spacing="8">
                    <StackPanel
                        x:Name="ItemsPanel"
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="10" />
                    <TextBlock
                        x:Name="StatusText"
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource SfTextRegular}"
                        FontSize="11"
                        Foreground="#B8F4F7FB"
                        Text="No windows available" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
