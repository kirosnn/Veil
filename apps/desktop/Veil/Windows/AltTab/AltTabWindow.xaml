<Window
    x:Class="Veil.Windows.AltTabWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent">
        <Border
            x:Name="PanelBorder"
            Width="1120"
            Padding="18"
            Background="Transparent"
            BorderThickness="1"
            CornerRadius="30">
            <StackPanel Spacing="14">
                <ScrollViewer
                    x:Name="ItemsScrollViewer"
                    HorizontalScrollBarVisibility="Hidden"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled"
                    ZoomMode="Disabled">
                    <StackPanel
                        x:Name="ItemsPanel"
                        Orientation="Horizontal"
                        Spacing="14" />
                </ScrollViewer>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        x:Name="SelectedMetaPanel"
                        Spacing="3">
                        <TextBlock
                            x:Name="SelectedWindowTitleText"
                            FontSize="15"
                            FontFamily="{StaticResource SfTextSemibold}"
                            Foreground="#F2FFFFFF"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            x:Name="SelectedWindowSubtitleText"
                            FontSize="12"
                            FontFamily="{StaticResource SfTextRegular}"
                            Foreground="#B8FFFFFF"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>

                    <TextBlock
                        x:Name="SelectionText"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontSize="12"
                        FontFamily="{StaticResource SfTextMedium}"
                        Foreground="#A8FFFFFF" />
                </Grid>

                <TextBlock
                    x:Name="HintText"
                    HorizontalAlignment="Center"
                    FontSize="11"
                    FontFamily="{StaticResource SfTextMedium}"
                    Foreground="#90FFFFFF"
                    Text="Tab to switch • release Alt to open" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
