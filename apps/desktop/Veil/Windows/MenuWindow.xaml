    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent">
        <Border
            x:Name="PanelBorder"
            Width="150"
            Padding="0"
            Background="Transparent"
            CornerRadius="14">
            <StackPanel
                x:Name="MenuItemsPanel"
                Margin="6"
                Width="138"
                Spacing="2" />
        </Border>
    </Grid>
</Window>
