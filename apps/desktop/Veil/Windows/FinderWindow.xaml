<Window
    x:Class="Veil.Windows.FinderWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent" IsTabStop="False">
        <Border
            x:Name="PanelBorder"
            Padding="0"
            Background="Transparent"
            CornerRadius="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <Grid
                    Grid.Row="0"
                    Margin="16,14,16,0"
                    Height="42"
                    ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        x:Name="SearchIcon"
                        Text="&#xE721;"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="18"
                        Foreground="#66FFFFFF"
                        VerticalAlignment="Center"
                        Margin="2,0,0,0" />

                    <Grid Grid.Column="1">
                        <TextBlock
                            x:Name="SearchPlaceholder"
                            Text="Search"
                            FontSize="18"
                            FontFamily="{StaticResource SfTextRegular}"
                            Foreground="#44FFFFFF"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False" />
                        <TextBlock
                            x:Name="AutocompleteHint"
                            FontSize="18"
                            FontFamily="{StaticResource SfTextRegular}"
                            VerticalAlignment="Center"
                            IsHitTestVisible="False"
                            Visibility="Collapsed" />
                        <TextBox
                            x:Name="SearchTextBox"
                            BorderThickness="0"
                            Background="Transparent"
                            Foreground="White"
                            FontSize="18"
                            FontFamily="{StaticResource SfTextRegular}"
                            VerticalAlignment="Center"
                            Padding="0"
                            SelectionHighlightColor="#4488AAFF"
                            TextChanged="OnSearchTextChanged"
                            KeyDown="OnSearchKeyDown">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="MinHeight" Value="0" />
                                    <Setter Property="MinWidth" Value="0" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <ScrollViewer
                                                    x:Name="ContentElement"
                                                    HorizontalScrollBarVisibility="Hidden"
                                                    HorizontalScrollMode="Auto"
                                                    VerticalScrollBarVisibility="Disabled"
                                                    VerticalScrollMode="Disabled"
                                                    VerticalAlignment="Center"
                                                    Margin="0"
                                                    Padding="0" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>

                    <Border
                        x:Name="SearchShortcutHint"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Margin="0,0,2,0"
                        Padding="6,2,6,2"
                        CornerRadius="4"
                        Background="#10FFFFFF"
                        Visibility="Collapsed">
                        <TextBlock
                            Text="ESC"
                            FontSize="10"
                            FontFamily="{StaticResource SfTextMedium}"
                            Foreground="#44FFFFFF" />
                    </Border>
                </Grid>

                <!-- Separator -->
                <Border
                    x:Name="Separator"
                    Grid.Row="1"
                    Height="1"
                    Margin="0,8,0,0"
                    Background="#12FFFFFF" />

                <!-- Results area -->
                <Grid Grid.Row="2">
                    <ScrollViewer
                        x:Name="ResultsScrollViewer"
                        Padding="0,2,0,2"
                        VerticalScrollBarVisibility="Hidden"
                        VerticalScrollMode="Auto">
                        <StackPanel x:Name="ResultsPanel" Spacing="0" />
                    </ScrollViewer>

                    <Border
                        x:Name="EmptyStatePanel"
                        Background="Transparent"
                        Visibility="Collapsed">
                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="2">
                            <TextBlock
                                x:Name="EmptyStateTitleText"
                                Text="No Results"
                                FontSize="14"
                                FontFamily="{StaticResource SfTextSemibold}"
                                Foreground="#55FFFFFF"
                                HorizontalAlignment="Center" />
                            <TextBlock
                                x:Name="EmptyStateSubtitleText"
                                Text="Try a different search."
                                FontSize="12"
                                FontFamily="{StaticResource SfTextRegular}"
                                Foreground="#33FFFFFF"
                                HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Status bar -->
                <Border
                    x:Name="StatusBar"
                    Grid.Row="3"
                    Height="28"
                    Background="#08FFFFFF">
                    <Grid Margin="14,0">
                        <TextBlock
                            x:Name="ResultCountText"
                            Text=""
                            FontSize="11"
                            FontFamily="{StaticResource SfTextRegular}"
                            Foreground="#33FFFFFF"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Left" />
                        <TextBlock
                            x:Name="HintText"
                            Text="↵ Open"
                            FontSize="11"
                            FontFamily="{StaticResource SfTextRegular}"
                            Foreground="#33FFFFFF"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right" />
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
